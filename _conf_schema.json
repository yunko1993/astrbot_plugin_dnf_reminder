{
  "configured_reminders": {
    "description": "控制台提醒列表",
    "type": "template_list",
    "hint": "每条配置就是一个完整提醒，包含时间、内容、发送目标和 @ 对象。命令添加的提醒仍会保存在 reminders.json 中。",
    "display_item": "title",
    "templates": {
      "daily_reminder": {
        "name": "每日提醒",
        "hint": "每天在指定时间发送一次提醒。",
        "display_item": "title",
        "items": {
          "enabled": {
            "description": "启用这条提醒",
            "type": "bool",
            "default": true
          },
          "title": {
            "description": "提醒标题",
            "type": "string",
            "hint": "只用于控制台列表里区分不同提醒，例如：心悦增幅器、每周团本、每日签到。",
            "default": "每日提醒"
          },
          "time": {
            "description": "提醒时间",
            "type": "string",
            "hint": "24 小时制，格式 HH:MM，例如 10:30。",
            "default": "10:00"
          },
          "content": {
            "description": "提醒内容",
            "type": "text",
            "hint": "到点后发送的文本内容。",
            "default": ""
          },
          "targets": {
            "description": "发送目标",
            "type": "list",
            "hint": "每项填写一个群会话 ID、unified_msg_origin 或纯群号。建议优先填写 /sid 得到的完整会话 ID。",
            "default": []
          },
          "mention_mode": {
            "description": "@ 对象",
            "type": "string",
            "hint": "选择这条提醒发送时要 @ 的对象。",
            "default": "none",
            "options": ["none", "user", "all"],
            "labels": ["不 @", "@ 指定人", "@ 所有人"]
          },
          "mention_user_id": {
            "description": "指定人 QQ 号",
            "type": "string",
            "hint": "当 @ 对象选择“@ 指定人”时填写。",
            "default": ""
          }
        }
      }
    }
  },
  "send_private_copy": {
    "description": "发送私聊副本",
    "type": "bool",
    "default": true,
    "invisible": true
  },
  "send_to_configured_groups": {
    "description": "发送到配置群",
    "type": "bool",
    "default": false,
    "invisible": true
  },
  "group_targets": {
    "description": "旧版群目标列表",
    "type": "list",
    "default": [],
    "invisible": true
  },
  "mention_all_on_group": {
    "description": "旧版群消息时 @所有人",
    "type": "bool",
    "default": false,
    "invisible": true
  },
  "delivery_settings": {
    "description": "旧版发送设置",
    "type": "object",
    "invisible": true,
    "items": {
      "send_private_copy": {
        "description": "发送私聊副本",
        "type": "bool",
        "default": true
      },
      "send_to_configured_groups": {
        "description": "发送到配置群",
        "type": "bool",
        "default": false
      }
    }
  },
  "group_settings": {
    "description": "旧版群目标设置",
    "type": "object",
    "invisible": true,
    "items": {
      "group_targets": {
        "description": "群目标列表",
        "type": "list",
        "default": []
      }
    }
  },
  "mention_settings": {
    "description": "旧版 @ 提醒设置",
    "type": "object",
    "invisible": true,
    "items": {
      "mention_all_on_group": {
        "description": "群消息时 @所有人",
        "type": "bool",
        "default": false
      }
    }
  }
}
