{
  "configured_reminders": {
    "description": "控制台提醒列表",
    "type": "template_list",
    "hint": "每条配置就是一个完整提醒，包含时间、内容、发送目标和 @ 对象。命令添加的提醒仍会保存在 reminders.json 中。",
    "display_item": "title",
    "templates": {
      "daily_reminder": {
        "name": "提醒条目",
        "hint": "展开后可编辑标题、时间、内容、发送目标和 @ 对象。",
        "display_item": "title",
        "items": {
          "enabled": {
            "description": "启用这条提醒",
            "type": "bool",
            "default": true
          },
          "title": {
            "description": "提醒标题",
            "type": "string",
            "hint": "只用于控制台列表里区分不同提醒，例如：心悦增幅器、每周团本、每日签到。",
            "default": "每日提醒"
          },
          "time": {
            "description": "提醒时间",
            "type": "string",
            "hint": "24 小时制，格式 HH:MM，例如 10:30。",
            "default": "10:00"
          },
          "content": {
            "description": "提醒内容",
            "type": "text",
            "hint": "到点后发送的文本内容。",
            "default": ""
          },
          "targets": {
            "description": "发送目标",
            "type": "list",
            "hint": "每项填写一个群会话 ID、unified_msg_origin 或纯群号。建议优先填写 /sid 得到的完整会话 ID。",
            "default": []
          },
          "target_prefix": {
            "description": "纯群号平台前缀",
            "type": "string",
            "hint": "当发送目标填写纯群号时使用。你的日志里显示为 napcat_1(aiocqhttp)，通常应填写 napcat_1；也可填写 auto，让 /提醒测试 时自动从当前会话学习。",
            "default": "napcat_1"
          },
          "mention_mode": {
            "description": "@ 对象",
            "type": "string",
            "hint": "选择这条提醒发送时要 @ 的对象。",
            "default": "none",
            "options": ["none", "user", "all"],
            "labels": ["不 @", "@ 指定人", "@ 所有人"]
          },
          "mention_user_ids": {
            "description": "指定人 QQ 号列表",
            "type": "list",
            "hint": "当 @ 对象选择“@ 指定人”时填写。每项一个 QQ 号，可添加多个。",
            "default": []
          },
          "mention_user_id": {
            "description": "旧版指定人 QQ 号",
            "type": "string",
            "default": "",
            "invisible": true
          }
        }
      }
    }
  }
}
